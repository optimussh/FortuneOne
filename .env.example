# Local default: SQLite (회원가입·프로필 파일 DB)
DATABASE_URL=sqlite+aiosqlite:///./data/fortuneone.db
# Optional Postgres:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/saasdb

SECRET_KEY=your-super-secret-key-2026
RESEND_API_KEY=
FRONTEND_URL=http://localhost:6100
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Payments (mock fully testable; toss when keys ready) ---
# mock | toss
PAYMENT_PROVIDER=mock
PAYMENT_TEST_MODE=true
# Toss test: test_ck_... / test_sk_...
# Toss live: live_ck_... / live_sk_... + PAYMENT_TEST_MODE=false
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# Business disclosure (site + /api/payments/config)
BUSINESS_NAME=FortuneOne
BUSINESS_CEO=[대표자명]
BUSINESS_NUMBER=[사업자등록번호]
BUSINESS_MAIL_ORDER=[통신판매업 신고번호]
BUSINESS_ADDRESS=[사업장 주소]
BUSINESS_PHONE=[고객센터]
BUSINESS_EMAIL=support@fortuneone.local
